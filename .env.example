SECRET_KEY=change-me-use-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# Postgres (Docker: host=db, lokalnie bez Dockera: localhost)
DATABASE_URL=postgres://staymap:staymap_secret@db:5432/staymap_dev

REDIS_URL=redis://redis:6379/0

# Pytest w kontenerze backend (docker-compose ustawia TEST_DATABASE_HOST=db)
# Lokalnie bez Dockera: TEST_DATABASE_HOST=localhost
# TEST_DATABASE_NAME=staymap_test
# TEST_DATABASE_USER=staymap
# TEST_DATABASE_PASSWORD=staymap_secret

# Produkcja — opcjonalnie S3 (django-storages); DJANGO_SETTINGS_MODULE=config.settings.production
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-central-1

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

EMAIL_FROM=noreply@staymap.pl
# Dev: console | Wysyłka Gmail (SMTP): ustaw hasło aplikacji (Google Account → Security → 2FA → App passwords)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=twoj@gmail.com
# EMAIL_HOST_PASSWORD=haslo-aplikacji-16-znakow

# Sentry (pakiet w requirements/base.txt; production: DJANGO_SETTINGS_MODULE=config.settings.production)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_SEND_DEFAULT_PII=False
# SENTRY_RELEASE=staymap@1.0.0  # lub GIT_COMMIT / RENDER_GIT_COMMIT
# Dev: wysyłka do Sentry tylko gdy ustawisz DSN i:
# SENTRY_ENABLE_DEV=True

# Frontend — przeglądarka woła hosta; SSR w Dockerze używa INTERNAL_API_URL z compose
NEXT_PUBLIC_API_URL=http://localhost:8000

# Next.js BFF (`frontend/src/app/api/v1/...`) → Django. W Dockerze: http://backend:8000
DJANGO_API_URL=http://localhost:8000
# Pełny URL aplikacji Next (SSR fetch do BFF). Lokalnie: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Next.js middleware (jose): weryfikacja JWT z ciasteczka access_token — musi być identyczny z SECRET_KEY Django.
JWT_SECRET=change-me-use-get-random-secret-key

# Geokodowanie: backend woła Nominatim (OSM). Ustaw własny User-Agent z kontaktem (polityka OSM).
# NOMINATIM_USER_AGENT=StayMapPolska/1.0 (+https://twoja-domena.pl; contact@twoja-domena.pl)
# Opcjonalnie własna instancja: NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search

# API: GET /api/v1/listings/<slug>/price-calendar/?from=YYYY-MM-DD&to=YYYY-MM-DD (opcjonalnie; bez parametrów = bieżący miesiąc)

# Etap 4 — POI (Overpass). Domyślnie ten sam User-Agent co Nominatim; możesz nadpisać.
# OVERPASS_INTERPRETER_URL=https://overpass-api.de/api/interpreter
# OVERPASS_USER_AGENT=StayMapPolska/1.0 (+https://twoja-domena.pl; contact@twoja-domena.pl)

# --- Etap 3: rezerwacje / cennik ---
FRONTEND_URL=http://localhost:3000
# PLATFORM_SERVICE_FEE_PERCENT=15
# DEFAULT_HOLIDAY_PRICE_MULTIPLIER=1.15
# HOST_REQUEST_ACCEPT_HOURS=24

# Płatności (Stripe itd.) — na później; na razie rezerwacje bez płatności online.
# BOOKING_PAYMENT_TIMEOUT_H=1
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
# CELERY_TASK_ALWAYS_EAGER=False
#
# Worker + Beat (opcjonalnie): docker compose --profile celery up -d
# Beat uruchamia m.in.: odświeżanie cache POI (Overpass, ~03:05) i opisów okolicy (~04:10), strefa Europe/Warsaw.

# --- Etap 5: AI search (OpenAI-compatible) ---
# OpenAI: zostaw OPENAI_BASE_URL puste; ustaw OPENAI_API_KEY z https://platform.openai.com/api-keys
# Groq (duży darmowy limit, ten sam protokół co OpenAI): https://console.groq.com/keys
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=gsk_...
#   OPENAI_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=800
# AI_SESSION_TTL_HOURS=24
# AI_MAX_LISTING_IDS_PER_SESSION=500

# --- Etap 5: porównanie ofert ---
# COMPARE_SESSION_TTL_HOURS=48
# COMPARE_MAX_LISTINGS=3
