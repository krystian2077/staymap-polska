SECRET_KEY=change-me-use-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

DATABASE_URL=postgres://staymap:staymap_secret@db:5432/staymap_dev

REDIS_URL=redis://redis:6379/0


JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

EMAIL_FROM=noreply@staymap.pl
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend


NEXT_PUBLIC_API_URL=http://localhost:8000

DJANGO_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=


JWT_SECRET=change-me-use-get-random-secret-key


FRONTEND_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=

# Cloudflare R2 — storage zdjęć (produkcja)
# Ustaw USE_S3=True na Railway żeby zdjęcia działały z R2
USE_S3=False
AWS_STORAGE_BUCKET_NAME=staymap-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
# Opcjonalne — custom domain na buckecie (np. media.staymap.pl)
AWS_S3_CUSTOM_DOMAIN=

# Cloudflare R2 — skrypt upload_to_r2.py (lokalnie)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=staymap-media

